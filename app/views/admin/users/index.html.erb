<h1>Users List - Role: <%= params[:role].presence || 'all' %></h1>

<!-- 🔘 Role Filter -->
<%= form_with url: admin_users_path, method: :get, local: true do %>
  <div style="margin-bottom: 1rem;">
    <label>
      <%= radio_button_tag :role, 'user', params[:role] == 'user' %> User
    </label>
    <label style="margin-left: 1rem;">
      <%= radio_button_tag :role, 'admin', params[:role] == 'admin' %> Admin
    </label>
    <%= submit_tag "Filter", style: "margin-left: 1rem;" %>
  </div>
<% end %>

<!-- ➕ Add Admin Button -->
<div style="margin-bottom: 1rem;">
  <%= link_to "➕ Add New Admin", new_admin_user_path, class: "add-admin-button", style: "padding: 0.5rem 1rem; background: green; color: white; text-decoration: none;" %>
</div>
<% if flash[:success] %>
  <p style="color: green;"><%= flash[:success] %></p>
<% end %>

<% if flash[:error] %>
  <p style="color: red;"><%= flash[:error] %></p>
<% end %>
<% if @users.any? %>
  <table border="1" cellpadding="5" cellspacing="0">
    <thead>
    <tr>
      <th>Name</th>
      <th>Email</th>
      <th>Role</th>
      <th>Actions</th>
    </tr>
    </thead>
    <tbody>
    <% @users.each do |user| %>
      <tr>
        <td><%= user.name %></td>
        <td><%= user.email %></td>
        <td><%= user.role %></td>
        <td>
          <%= link_to "Show", admin_user_path(user) %> |
          <%= button_to "Delete", admin_user_path(user, role: params[:role]), method: :delete, data: { confirm: "Are you sure?" } %>
        </td>
      </tr>
    <% end %>
    </tbody>
  </table>
<% else %>
  <p>No users found.</p>
<% end %>
<%= pagy_nav(@pagy).html_safe %>


<%= link_to "← Back to Admin Dashboard", admin_movies_path, style: "display: inline-block; margin-top: 1rem;" %>
