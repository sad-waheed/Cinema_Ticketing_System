<h1>Add Show</h1>

<%= form_with model: @show, url: admin_shows_path, local: true do |f| %>
  <%= hidden_field_tag :authenticity_token, form_authenticity_token %>

  <!-- 🎬 Movie Dropdown -->
  <div style="margin-bottom: 1rem;">
    <label for="movie_id">Movie</label><br>
    <%= select_tag 'show[movie_id]',
                   options_from_collection_for_select(Movie.all, :id, :title, @movie&.id),
                   disabled: true %>
    <%= hidden_field_tag 'show[movie_id]', @movie&.id %>
  </div>

  <!-- 🏟️ Hall Dropdown -->
  <div style="margin-bottom: 1rem;">
    <label for="hall_id">Select Hall</label><br>
    <%= select_tag 'show[hall_id]', options_from_collection_for_select(@halls, :id, :name), prompt: "Choose a hall" %>
  </div>

  <!-- 📅 Date -->
  <div style="margin-bottom: 1rem;">
    <label>Date</label><br>
    <%= date_field_tag 'show[date]', nil, required: true %>
  </div>
  <div style="margin-bottom: 1rem;">
    <label>Start Time</label><br>
    <%= time_field_tag 'show[start_time]', nil, required: true %>
  </div>

  <%= f.submit "Create Show", style: "padding: 0.5rem 1rem; background: blue; color: white;" %>
<% end %>

<%= link_to "← Back to Movie", admin_movie_path(@movie), style: "display: inline-block; margin-top: 1rem;" %>
