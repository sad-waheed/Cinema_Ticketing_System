<h1>Edit Show for <%= @movie.title %></h1>

<%= form_with model: [:admin, @show], local: true do |f| %>
  <% if flash[:alert] %>
    <p style="color: red;"><%= flash[:alert] %></p>
  <% end %>

  <div>
    <%= f.label :date, "Date" %><br>
    <%= date_field_tag 'show[date]', @show.start_time.to_date %>
  </div>

  <div>
    <%= f.label :start_time, "Start Time" %><br>
    <%= time_field_tag 'show[start_time]', @show.start_time.strftime("%H:%M") %>
  </div>

  <div>
    <%= f.label :hall_id, "Hall" %><br>
    <%= f.collection_select :hall_id, @halls, :id, :name, prompt: "Select Hall" %>
  </div>

  <div>
    <%= f.submit "Update Show" %>
  </div>
<% end %>

<%= link_to 'Back to Movie', admin_movie_path(@movie) %>
