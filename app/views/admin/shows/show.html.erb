<h1>Show Details</h1>
<%= link_to "Edit Show", edit_admin_show_path(@show), class: "button", style: "margin-bottom: 10px;" %>


<% if flash[:notice] %>
  <p style="color: green;"><%= flash[:notice] %></p>
<% end %>

<p><strong>Movie:</strong> <%= @show.movie.title %></p>
<p><strong>Hall:</strong> <%= @show.hall.name %></p>
<p><strong>Start Time:</strong> <%= @show.start_time.strftime("%A, %B %d %Y at %I:%M %p") %></p>
<p><strong>End Time:</strong> <%= @show.end_time.strftime("%I:%M %p") %></p>

<hr>

<h2>Bookings</h2>

<% if @bookings.any? %>
  <table border="1" cellpadding="5" cellspacing="0">
    <thead>
    <tr>
      <th>User</th>
      <th>Seats</th>
      <th>Status</th>
      <th>Booked At</th>
      <th>Actions</th>
    </tr>
    </thead>
    <tbody>
    <% @bookings.each do |booking| %>
      <tr>
        <td><%= booking.user.name %> (<%= booking.user.email %>)</td>
        <td>
          <%= booking.seats.map { |seat| "#{seat.row}#{seat.seat_number}" }.join(", ") %>
        </td>
        <td><%= booking.status.capitalize %></td>
        <td><%= booking.created_at.strftime("%B %d, %Y %I:%M %p") %></td>
        <td>
          <%= button_to "Delete", admin_booking_path(booking), method: :delete, data: { confirm: "Are you sure?" } %>
        </td>
      </tr>
    <% end %>
    </tbody>
  </table>

  <br>
  <%= pagy_nav(@pagy).html_safe %>
<% else %>
  <p>No bookings for this show yet.</p>
<% end %>

<br>
<%= link_to "← Back to Movie", admin_movie_path(@show.movie), style: "text-decoration: underline;" %>
