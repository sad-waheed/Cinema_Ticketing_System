<h1>🎬 All Movies</h1>

<% if flash[:notice] %>
  <p style="color: green;"><%= flash[:notice] %></p>
<% end %>
<% if flash[:error] %>
  <p style="color: red;"><%= flash[:error] %></p>
<% end %>
<% if flash[:success] %>
  <p style="color: green;"><%= flash[:success] %></p>
<% end %>

<% if @movies.any? %>
  <table border="1" cellpadding="5" cellspacing="0">
    <thead>
    <tr>
      <th>Image</th>
      <th>Title</th>
      <th>Rating</th>
      <th>Duration</th>
      <th>Actions</th>
    </tr>
    </thead>
    <tbody>
    <% @movies.each do |movie| %>
      <tr>
        <td style="width: 100px; text-align: center;">
          <% if movie.image_data.present? %>
            <img src="<%= movie.image_base64 %>" alt="Image of <%= movie.title %>" style="max-width: 80px; max-height: 80px;" />
          <% else %>
            <em>No Image</em>
          <% end %>
        </td>
        <td><%= link_to movie.title, admin_movie_path(movie), style: "text-decoration: underline; color: blue;" %></td>
        <td><%= movie.rating %></td>
        <td><%= movie.duration %> minutes</td>
        <td>
          <%= link_to "Edit", edit_admin_movie_path(movie), class: "btn", style: "margin-right: 5px;" %>
          <%= button_to "Delete", admin_movie_path(movie), method: :delete, data: { confirm: "Are you sure?" } %>
        </td>
      </tr>
    <% end %>
    </tbody>
  </table>

  <!-- Pagy controls -->
  <%= pagy_nav(@pagy).html_safe %>

<% else %>
  <p>No movies available.</p>
<% end %>

<br>
<%= link_to "➕ Add New Movie", new_admin_movie_path, class: "btn", style: "background: green; color: white; padding: 0.5rem; text-decoration: none;" %>
<br><br>
