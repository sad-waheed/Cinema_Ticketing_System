<h1>Edit Movie: <%= @movie.title %></h1>

<% if flash[:error] %>
  <p style="color: red;"><%= flash[:error].join(", ") %></p>
<% end %>

<%= form_with model: @movie, url: admin_movie_path(@movie), method: :patch, local: true, html: { multipart: true } do |f| %>
  <div>
    <%= f.label :title %><br>
    <%= f.text_field :title, required: true %>
  </div>

  <div>
    <%= f.label :rating %><br>
    <%= f.select :rating, ["PG-13", "R", "G", "NC-17"], prompt: "Select Rating", required: true, selected: @movie.rating %>
  </div>

  <div>
    <%= f.label :duration, "Duration (in minutes)" %><br>
    <%= f.number_field :duration, required: true %>
  </div>

  <div>
    <p>Current Image:</p>
    <% if @movie.image_data.present? %>
      <img src="<%= @movie.image_base64 %>" alt="Image of <%= @movie.title %>" style="max-width: 200px; max-height: 200px;" />
    <% else %>
      <em>No Image Uploaded</em>
    <% end %>
  </div>

  <div>
    <%= f.label :image, "Change Movie Image (optional)" %><br>
    <%= f.file_field :image, accept: "image/*" %>
  </div>

  <div>
    <%= f.submit "Update Movie" %>
  </div>
<% end %>

<br>
<%= link_to "← Back to Movies", admin_movies_path %>
