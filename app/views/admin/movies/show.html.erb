<h1><%= @movie.title %></h1>

<% if @movie.image_data.present? %>
  <img src="<%= @movie.image_base64 %>" alt="Image of <%= @movie.title %>" style="max-width: 300px; max-height: 300px; margin-bottom: 1rem;" />
<% end %>

<p><strong>Rating:</strong> <%= @movie.rating %></p>
<p><strong>Duration:</strong> <%= @movie.duration %> minutes</p>

<hr>

<h2>Showtimes</h2>

<div style="margin-bottom: 1rem;">
  <%= link_to "➕ Add Show", new_admin_show_path(movie_id: @movie.id), class: "btn", style: "background: green; color: white; padding: 0.5rem 1rem; text-decoration: none;" %>
</div>

<% if @shows.any? %>
  <ul>
    <% @shows.each do |show| %>
      <li>
        <%= show.start_time.strftime("%A, %B %d %Y at %I:%M %p") %> —
        <strong>Hall:</strong> <%= show.hall.name %>
        <%= link_to "View Show", admin_show_path(show), style: "margin-left: 1rem;" %> |
        <%= button_to "Delete Show", admin_show_path(show), method: :delete, data: { confirm: "Are you sure you want to delete this show?" }, style: "margin-left: 1rem;" %>
      </li>
    <% end %>
  </ul>
  <%= pagy_nav(@pagy).html_safe %>
<% else %>
  <p>No shows scheduled for this movie yet.</p>
<% end %>

<br>
<%= link_to "← Back to Movies", admin_movies_path %>
