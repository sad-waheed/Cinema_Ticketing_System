<h1>🎟️ All Halls</h1>

<!-- Flash Messages -->
<% flash.each do |key, message| %>
  <p style="color: <%= key == 'notice' || key == 'success' ? 'green' : 'red' %>;">
    <%= message %>
  </p>
<% end %>

<!-- Add Hall Button -->
<div style="margin-bottom: 1rem;">
  <%= link_to "➕ Add Hall", new_admin_hall_path, class: "btn", style: "background: green; color: white; padding: 0.5rem 1rem; text-decoration: none;" %>
</div>

<% if @halls.any? %>
  <table border="1" cellpadding="5" cellspacing="0">
    <thead>
    <tr>
      <th>Hall Name</th>
      <th>Seats Count</th>
      <th>Actions</th>
    </tr>
    </thead>
    <tbody>
    <% @halls.each do |hall| %>
      <tr>
        <td>
          <%= link_to hall.name, admin_hall_path(hall), style: "text-decoration: underline;" %>
        </td>
        <td><%= hall.seats_count || hall.seats.size %></td>
        <td>
          <%= button_to "🗑️ Delete", admin_hall_path(hall), method: :delete, data: { confirm: "Are you sure you want to delete this hall?" }, style: "color: red;" %>
        </td>
      </tr>
    <% end %>
    </tbody>
  </table>
<% else %>
  <p>No halls found.</p>
<% end %>
<%= pagy_nav(@pagy).html_safe %>

<br>
<%= link_to "← Back to Home", admin_movies_path %>
